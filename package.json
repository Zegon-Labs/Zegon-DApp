{
  "name": "zegon-dapp",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter @zegon/game-server --filter @zegon/game-client dev",
    "dev:client": "pnpm --filter @zegon/game-client dev",
    "dev:og": "pnpm --filter @zegon/game-client dev",
    "dev:server": "pnpm --filter @zegon/game-server dev",
    "dev:full": "pnpm --parallel --filter @zegon/game-server --filter @zegon/game-client dev",
    "build": "pnpm -r build",
    "vercel-build": "pnpm --filter @zegon/game-core build && pnpm --filter @zegon/game-server build && pnpm --filter @zegon/game-client build",
    "test": "pnpm --filter @zegon/game-core test && pnpm --filter @zegon/game-server test",
    "test:contracts": "pnpm --filter @zegon/contracts test",
    "compile": "pnpm --filter @zegon/contracts compile",
    "deploy:galileo": "pnpm --filter @zegon/contracts run deploy",
    "deploy:pool": "pnpm --filter @zegon/contracts run deploy:pool",
    "smoke:galileo": "pnpm --filter @zegon/contracts smoke:galileo",
    "smoke:compute": "pnpm --filter @zegon/game-server smoke:compute"
  },
  "devDependencies": {
    "@vercel/node": "^5.1.8",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@9.15.4"
}
