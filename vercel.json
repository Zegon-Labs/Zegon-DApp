{
  "version": 2,
  "installCommand": "pnpm install",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "packages/game-client/dist" }
    },
    {
      "src": "packages/game-server/api/duel/[...slug].ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/packages/game-server/api/duel/[...slug].ts" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/packages/game-client/dist/index.html" }
  ]
}
