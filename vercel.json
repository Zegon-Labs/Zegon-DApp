{
  "version": 2,
  "installCommand": "pnpm install",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "packages/game-client/dist" }
    },
    {
      "src": "api/[...slug].ts",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 60
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/[...slug].ts?slug=$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/packages/game-client/dist/index.html" }
  ]
}
