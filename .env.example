# Wallet del operador (backend + Hardhat deploy). Obtener fondos en https://faucet.0g.ai
SERVER_WALLET_PRIVATE_KEY=

# Red Galileo testnet
OG_RPC_URL=https://evmrpc-testnet.0g.ai

# Address del contrato ZegonDuel desplegado en Galileo
ZEGON_DUEL_CONTRACT_ADDRESS=

# Backend: usar inferencia 0G Compute (TEE). false = DummyZegonBrain en servidor
USE_OG_COMPUTE=false

# Cliente Vite: usar API del servidor en lugar de brain local
VITE_USE_OG_COMPUTE=false

# Modelo 0G Compute (confirmar en catálogo del broker)
OG_MODEL=glm-5-fp8

# 0G Storage indexer (turbo testnet)
OG_STORAGE_INDEXER=https://indexer-storage-turbo.0g.ai

# OG tokens a depositar en ledger Compute (mínimo ~3 OG para crear ledger)
OG_LEDGER_DEPOSIT_OG=3

# Directorios locales (dev / fallback)
DUEL_LOG_DIR=.duel-logs
DUEL_SESSION_DIR=.duel-sessions
LEADERBOARD_DIR=.leaderboard

# Puerto del API dev server
PORT=3000
